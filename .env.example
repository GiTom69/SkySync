# Amadeus for Developers (free at developers.amadeus.com)
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# Use 'test' for sandbox (recommended to start), 'production' for live data
AMADEUS_ENV=test

# Optional: Email alerts via SMTP (Gmail example)
# For Gmail, use an App Password: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# App settings
APP_HOST=127.0.0.1
APP_PORT=8000
